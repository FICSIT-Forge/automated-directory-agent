{
  "name": "functions",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "build": "pnpm build:ts && pnpm lint && pnpm format:check",
    "build:ts": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx --watch 'src/index.ts'",
    "genkit:dev": "genkit start -- pnpm run dev",
    "genkit:emulate": "genkit start -- firebase emulators:start --inspect-functions",
    "build:index": "tsx scripts/buildIndex.ts",
    "verify:index": "tsx scripts/verifyIndex.ts",
    "verify:alternates": "tsx scripts/verifyAlternates.ts",
    "eval": "tsx scripts/evalRetrieval.ts",
    "mine:reddit": "tsx scripts/mineReddit.ts",
    "shell": "pnpm build && firebase functions:shell",
    "start": "pnpm shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": "22"
  },
  "type": "module",
  "main": "lib/index.js",
  "dependencies": {
    "@genkit-ai/firebase": "^1.39.0",
    "@genkit-ai/google-genai": "^1.39.0",
    "@google-cloud/functions-framework": "^5.0.5",
    "firebase-admin": "^14.1.0",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.39.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "firebase-functions-test": "^3.5.0",
    "genkit-cli": "^1.39.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "private": true
}
