rules_version = '2';

// Firestore is server-side only in this project: `turns`, `feedback`, and
// `rateLimits` are written by Cloud Functions through the Admin SDK, which
// bypasses these rules. The web app never talks to Firestore directly
// (feedback goes through the submitFeedback callable), so client access is
// denied outright. If a client-readable collection is ever added, carve out
// an explicit match block for it — do not loosen this catch-all.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
